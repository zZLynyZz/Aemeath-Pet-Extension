{
  "manifest_version": 3,
  "name": "Aemeath Pet",
  "version": "2.0",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon/icon16.png",
      "48": "icon/icon48.png",
      "128": "icon/icon128.png"
    }
  },
  "icons": {
    "16": "icon/icon16.png",
    "48": "icon/icon48.png",
    "128": "icon/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "concert.js", 
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["gif/*.gif"],
      "matches": ["<all_urls>"]
    }
  ]
}