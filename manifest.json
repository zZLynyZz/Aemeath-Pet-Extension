{
  "manifest_version": 3,
  "name": "Aemeath Pet",
  "version": "1.0",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icon/icon16.png",
    "48": "icon/icon48.png",
    "128": "icon/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["gif/*.gif"],
      "matches": ["<all_urls>"]
    }
  ]
}